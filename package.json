{
  "name": "@meimberg/ui",
  "version": "1.2.3",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "description": "Meimberg UI — das Design-System-Produkt. Komponenten (Default-Export) + Foundations/Preset unter @meimberg/ui/tokens. Consumer bauen die Quelle via Next transpilePackages (kein separater Build-Step).",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meimberg-io/io.meimberg.ui.git"
  },
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./tokens": "./src/tokens/theme.css",
    "./providers": "./src/providers.tsx",
    "./atoms/icons": "./src/atoms/icons.ts",
    "./organisms/markdown-editor": "./src/organisms/markdown-editor.tsx",
    "./molecules/markdown-renderer": "./src/molecules/markdown-renderer.tsx",
    "./cn": "./src/lib/cn.ts",
    "./hooks/use-mobile": "./src/hooks/use-mobile.ts",
    "./ui/action-icons": "./src/ui/action-icons.ts",
    "./ui/*": "./src/ui/*.tsx",
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "check:stories": "node scripts/check-storybook-coverage.mjs",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build -o storybook-static",
    "changeset": "changeset",
    "release:version": "changeset version"
